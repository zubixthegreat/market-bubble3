const randomSparkline = (base: number, volatility: number = 0.05): number[] => {
  const points: number[] = [];
  let current = base;
  for (let i = 0; i < 20; i++) {
    current = current * (1 + (Math.random() - 0.5) * volatility);
    points.push(current);
  }
  return points;
};

